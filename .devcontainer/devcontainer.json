{
    "name": "BookingSystem",
    "image": "mcr.microsoft.com/devcontainers/python:3.12",
    "features": {
        "ghcr.io/devcontainers/features/postgres:1": {
            "version": "14"
        }
    },
    "postCreateCommand": "pip install -r requirements.txt && python manage.py migrate && python manage.py loaddata spaces/fixtures/spaces.json",
    "forwardPorts": [8000],
    "portsAttributes": {
        "8000": {
            "label": "Django Server",
            "onAutoForward": "notify"
        }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance"
            ]
        }
    }
}